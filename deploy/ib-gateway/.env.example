TWS_USERID=replace-with-ibkr-username
TWS_PASSWORD=replace-with-ibkr-password
TRADING_MODE=live
READ_ONLY_API=no
TWS_ACCEPT_INCOMING=accept
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
EXISTING_SESSION_DETECTED_ACTION=primary
ALLOW_BLIND_TRADING=no
AUTO_RESTART_TIME=11:45 PM
TIME_ZONE=Asia/Kolkata
JAVA_HEAP_SIZE=768

# Optional but recommended for occasional GUI troubleshooting.
# If omitted, VNC is disabled.
# VNC_SERVER_PASSWORD=replace-with-vnc-password
