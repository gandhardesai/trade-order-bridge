APP_NAME=trade-order-bridge
DATABASE_URL=sqlite:////data/trade_order_bridge.db
ADMIN_TOKEN=replace-with-long-random-admin-token
KEY_HASH_ITERATIONS=120000
LOG_LEVEL=INFO
WEBHOOK_RATE_LIMIT_COUNT=30
WEBHOOK_RATE_LIMIT_WINDOW_SEC=60

# Adapter mode: stub (POC) or ibkr_live
BROKER_ADAPTER=stub

# IBKR connection (used when BROKER_ADAPTER=ibkr_live)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=23
IBKR_ACCOUNT=
